# Use Supabase's Session pooler URL (not "Direct connection"), which is IPv4
# reachable. The direct-connection host is IPv6-only and unreachable from
# most PaaS hosts (Render, Vercel, etc). Percent-encode special characters
# in the password (e.g. "*" -> "%2A").
DATABASE_URL=postgresql://postgres.your-project-ref:password@aws-0-region.pooler.supabase.com:5432/postgres
JWT_SECRET=change-me-to-a-random-64-char-string
MAGIC_LINK_SECRET=change-me-to-another-random-string
EMAIL_FROM=PortalFlow <noreply@mail.backlab.fr>
RESEND_API_KEY=re_your_resend_api_key
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_STORAGE_BUCKET=project-files
FRONTEND_URL=https://portalflow-landing-six.vercel.app,https://portalflow-dashboard.vercel.app
DASHBOARD_URL=https://portalflow-dashboard.vercel.app
BACKEND_URL=https://portalflow.onrender.com
NODE_ENV=development
PORT=3001
